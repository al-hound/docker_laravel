# Environment variables for the Laravel application
APP_NAME=Laravel            # Change this to your application name****
APP_PORT=8080               # Change this port in case of port conflicts with other applications****
VITE_PORT=5173              # Change this port in case of port conflicts with other applications****

# Database configuration
DB_CONNECTION=mysql
DB_HOST=mysql               # Change only if your service it's called different
DB_PORT=3306                # Change this port in case of port conflicts with other applications****
DB_DATABASE=laravel         # Change this to your database name
DB_USERNAME=root            # Change this to your database username
DB_PASSWORD=secret          # Change this to your database password
DB_ROOT_PASSWORD=secret     # Change this to your database root password

# Redis configuration
REDIS_HOST=redis
REDIS_PORT=6379             # Change this port in case of port conflicts with other applications****

# Mail configuration
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=username
MAIL_PASSWORD=secret
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="username@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Mailpit configuration
MAILPIT_DASHBOARD_PORT=8025 # Change this port in case of port conflicts with other applications****
MAILPIT_SMTP_PORT=1025      # Change this port in case of port conflicts with other applications****
